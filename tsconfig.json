{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["assets/*"],
      "@components/*": ["app/components/*"],
      "@screens/*": ["app/screens/*"],
      "@hooks/*": ["app/hooks/*"],
      "@theme/*": ["app/theme/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@domain/*": ["domain/*"],
    }
  },
}
